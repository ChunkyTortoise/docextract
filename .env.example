# DocExtract AI — Environment Variables
# Copy to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/docextract
REDIS_URL=redis://localhost:6379/0
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
# ZHIPUAI_API_KEY=                # GLM-4 Plus/Flash (Zhipu AI) — OpenAI-compatible
API_KEY_SECRET=change-me-32-chars-minimum-secret

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage/local
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=docextract

# ── Encryption ────────────────────────────────────────────────────────────────
AES_KEY=base64encodedkey==

# ── Model Configuration ──────────────────────────────────────────────────────
# EXTRACTION_MODELS=claude-sonnet-4-6,claude-haiku-4-5-20251001
# CLASSIFICATION_MODELS=claude-haiku-4-5-20251001,claude-sonnet-4-6
EXTRACTION_CONFIDENCE_THRESHOLD=0.8
# CONFIDENCE_THRESHOLDS={"invoice":0.80,"identity_document":0.90,"medical_record":0.90}
OCR_ENGINE=tesseract
# VISION_EXTRACTION_ENABLED=false

# ── Feature Flags ─────────────────────────────────────────────────────────────
# GRAPH_RETRIEVAL_ENABLED=false
# GRAPH_STORE_PATH=data/knowledge_graph.json
# GUARDRAILS_ENABLED=false
# ACTIVE_LEARNING_ENABLED=false
# SEMANTIC_CACHE_ENABLED=false
# DEMO_MODE=false
# DEMO_API_KEY=demo-key-docextract-2026

# ── Worker ────────────────────────────────────────────────────────────────────
WORKER_QUEUE=docextract
WORKER_MAX_JOBS=10
JOB_TIMEOUT_SECONDS=300

# ── Observability ─────────────────────────────────────────────────────────────
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317

# Langfuse cloud tracing (free tier: 1M spans/month)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Braintrust eval platform (scripts/eval_braintrust.py; free tier). Only the
# synthetic golden corpus is sent. Use `make eval-braintrust-dry` for no upload.
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=docextract

# ── Server ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:8501"]
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=50
MAX_PAGES=100
